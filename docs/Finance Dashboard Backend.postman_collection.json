        {
          "name": "Create Record - Negative Amount",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Should return 400 for negative amount\", function () {\r",
                  "    pm.response.to.have.status(400);\r",
                  "});\r",
                  "\r",
                  "const jsonData = pm.response.json();\r",
                  "\r",
                  "pm.test(\"Should fail validation\", function () {\r",
                  "    pm.expect(jsonData.success).to.eql(false);\r",
                  "    pm.expect(jsonData.message.toLowerCase()).to.include(\"validation\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Should contain amount field error\", function () {\r",
                  "    const hasAmountError = Array.isArray(jsonData.errors) &&\r",
                  "        jsonData.errors.some(err =>\r",
                  "            err.field === \"amount\" ||\r",
                  "            JSON.stringify(err).toLowerCase().includes(\"amount\")\r",
                  "        );\r",
                  "\r",
                  "    pm.expect(hasAmountError).to.eql(true);\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"amount\": -500,\r\n  \"type\": \"expense\",\r\n  \"category\": \"Food\",\r\n  \"date\": \"2026-04-20\",\r\n  \"note\": \"Negative amount test\"\r\n}",
              "options": {
